{
  "name": "@sldcyh/kook",
  "version": "0.1.0",
  "description": "Community KOOK channel plugin for OpenClaw",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sldcyh/openclaw-kook-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/sldcyh/openclaw-kook-plugin/issues"
  },
  "homepage": "https://github.com/sldcyh/openclaw-kook-plugin#readme",
  "keywords": [
    "openclaw",
    "plugin",
    "kook",
    "kaiheila",
    "bot"
  ],
  "files": [
    "index.ts",
    "openclaw.plugin.json",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "tsc -p tsconfig.json --noEmit",
    "pack:check": "npm pack --dry-run"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ws": "^8.18.3"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.11"
  },
  "devDependencies": {
    "@types/ws": "^8.5.14",
    "openclaw": "2026.3.11",
    "typescript": "^5.9.2"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "kook",
      "label": "KOOK",
      "selectionLabel": "KOOK (plugin)",
      "detailLabel": "KOOK Bot",
      "docsPath": "/channels/kook",
      "docsLabel": "kook",
      "blurb": "KOOK bot plugin with WebSocket events and basic DM/channel replies.",
      "aliases": [
        "kaiheila",
        "开黑啦"
      ],
      "order": 62
    },
    "install": {
      "npmSpec": "@sldcyh/kook",
      "localPath": "projects/openclaw-kook-plugin",
      "defaultChoice": "npm"
    }
  }
}
